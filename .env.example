# Copy this file to .env and fill in the values you want.
# docker-start.ps1 also writes PRAKTIS_CDP_URL automatically for this machine.

# Discord webhooks.
# Create them in Discord: Server Settings -> Integrations -> Webhooks -> New Webhook.
# Normal processing messages go to DISCORD_INFO_WEBHOOK_URL.
# Health problems, warnings, errors, and failed processing jobs go to DISCORD_ERROR_WEBHOOK_URL.
DISCORD_WEBHOOK_URL=
DISCORD_INFO_WEBHOOK_URL=https://discord.com/api/webhooks/1522497190705106965/Eurf-5Z-vVRC4rNXgHY0toyoLAezY7XXODd2s0UpTDZPpIRrKWTfv-Cfh0rxSuYXkV3f
DISCORD_ERROR_WEBHOOK_URL=https:https://discord.com/api/webhooks/1522508468953677824/7vccbiCnl4ZUNZ3ejUc-AmuPRgSOWQAF1Xtrrsxjz45ccCRyraq8sLs2dEyhUYoLGHXD

# ERROR sends only real failures to Discord.
# WARNING also sends blocked/health warnings.
# INFO also sends normal processing events and can be noisy.
DISCORD_LOG_LEVEL=ERROR
DISCORD_ERROR_LEVEL=WARNING
DISCORD_APP_NAME=Praktis Brochure Linker

# High-value Discord notifications from the app itself.
DISCORD_PROCESS_NOTIFICATIONS=1
DISCORD_STARTUP_NOTIFICATIONS=1

# Health monitor settings.
BROCHURE_HEALTH_INTERVAL_SECONDS=60
BROCHURE_HEALTH_REMINDER_SECONDS=1800
BROCHURE_HEALTH_PRAKTIS_URL=https://praktis.bg/
BROCHURE_MIN_FREE_DISK_MB=512

# Processing duration above this number is reported as a slow job.
BROCHURE_SLOW_SECONDS=600

# Chrome CDP endpoint used by Docker mode.
PRAKTIS_CDP_URL=http://192.168.65.254:9222
